    "#plugins/*": "./dist/plugins/*",
    "#services/*": "./dist/services/*",
    "#lib/*": "./dist/lib/*",
    "#utils/*": "./dist/utils/*"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
