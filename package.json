{
  "name": "anirban-be",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "imports": {
    "#config/*": "./dist/config/*",
    "#shared/*": "./dist/shared/*",
    "#resources/*": "./dist/resources/*",
    "#plugins/*": "./dist/plugins/*",
    "#services/*": "./dist/services/*",
    "#lib/*": "./dist/lib/*",
    "#utils/*": "./dist/utils/*"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
