{
  "name": "anirban-be",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "imports": {
    "#config/*": "./dist/config/*",
    "#shared/*": "./dist/shared/*",
