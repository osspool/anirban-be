    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/under-pressure": "^9.0.3",
    "better-auth": "^1.6.9",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "mongodb": "^7.1.0",
    "mongoose": "^9.6.1",
    "mongoose-timeline-audit": "^2.0.0",
