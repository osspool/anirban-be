# Environment Files (Next.js-style priority):
#   .env.local         → machine-specific overrides (gitignored)
#   .env.production    → production defaults
#   .env.development   → development defaults (or .env.dev)
#   .env               → shared defaults (fallback)
#
# Tip: Copy this file to .env.local for local development.

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=8040
HOST=0.0.0.0
# Switch to "production" before running `npm start` against a real DB. The
# auth config asserts BETTER_AUTH_SECRET is set + 32+ chars whenever
# NODE_ENV=production, and turns BA's rate-limiter on at the same time.
NODE_ENV=development

# -----------------------------------------------------------------------------
# Better Auth
# -----------------------------------------------------------------------------
# REQUIRED in production — minimum 32 random characters. The boot script
# throws if missing when NODE_ENV=production. Generate with:
#   openssl rand -hex 32   (or any 32+ byte secret)
BETTER_AUTH_SECRET=your-32-character-minimum-secret-here

# Public-facing URL of the FRONTEND. Used to build email-link templates
# (password-reset URL etc). MUST also appear in CORS_ORIGINS below or BA
# will 403 sign-ins from the browser with "Invalid origin".
FRONTEND_URL=http://localhost:3001

# Optional: full URL the BA handler answers on. Defaults to
#   http://localhost:${PORT}.
# Set this to the public BE URL in production so BA generates absolute
# links pointing at the right host.
# BETTER_AUTH_URL=https://api.anirban.example.org

# -----------------------------------------------------------------------------
# Bootstrap superadmin — created on first boot if missing.
# Idempotent: re-running boot just pins the role to `admin` on the user.
# After first boot, change the password from /dashboard/profile (Security
# tab) and remove these from your shared env to avoid leaking creds.
# -----------------------------------------------------------------------------
ANIRBAN_BOOTSTRAP_ADMIN_EMAIL=admin@anirban.example.org
ANIRBAN_BOOTSTRAP_ADMIN_PASSWORD=change-me-on-first-login

# -----------------------------------------------------------------------------
# CORS — comma-separated allow-list for browser origins hitting /api/*.
# Mirrored into BA's `trustedOrigins` automatically. FRONTEND_URL above
# MUST be in this list (or be the only entry).
#
# Options:
#   *                                  → allow all origins (dev only — BA
#                                        treats this as a wildcard skip)
#   https://anirban.example.org        → exact public origin (prod)
#   http://localhost:3001              → dev FE
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3001

# -----------------------------------------------------------------------------
# MongoDB
# -----------------------------------------------------------------------------
# Production: full mongodb+srv URI from Atlas/your provider, including
# credentials. Don't share the DB with any other arc-stack app.
MONGODB_URI=mongodb://localhost:27017/anirban-be

# -----------------------------------------------------------------------------
# SMTP (transactional email — password reset, invitations, ad-hoc broadcasts)
#
# When SMTP_HOST is set, real emails are sent via `@classytic/notifications`
# (nodemailer under the hood). Otherwise notifications fall back to the
# ConsoleChannel — useful in dev (admins copy the reset URL straight from
# the server log).
#
# Recommended provider — Resend (free tier: 100/day, 3000/month, 1 domain):
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=resend                  (literally the word "resend")
#   SMTP_PASS=re_xxxxxxxxxxxxx        (Resend API key — Sending access only)
#   SMTP_FROM="Anirban <info@yourdomain.com>"
#
# Domain setup (Cloudflare + Resend) is documented in
# /dashboard/email/setup once the FE is running. End-to-end walkthrough:
# D:/workspace/workflow_guides/email-setup-cloudflare-resend-gmail.md
#
# Other providers (drop-in — same env vars, different host/user/pass):
#   SendGrid:  host smtp.sendgrid.net    port 587  user "apikey"  pass <key>
#   Postmark:  host smtp.postmarkapp.com port 587  user/pass = server token
#   AWS SES:   host email-smtp.<region>.amazonaws.com port 587  IAM user/pass
#   Hostinger: host smtp.hostinger.com   port 465  user/pass = mailbox creds  (SMTP_SECURE=true)
#   Gmail:     host smtp.gmail.com       port 587  user <addr>  pass <app-password>
# -----------------------------------------------------------------------------
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=resend
# SMTP_PASS=
# SMTP_FROM="Anirban <noreply@anirban.example.org>"

# -----------------------------------------------------------------------------
# Cloudinary — image storage. The media engine boots a CloudinaryProvider
# at startup and pins every upload under the `anirban/` root folder
# (hard-coded in src/resources/media/media.engine.ts) — the account is
# shared with sibling client projects, so namespacing is required.
#
# Get credentials from https://console.cloudinary.com → Settings → API Keys.
# Free tier: 25 monthly credits ≈ 25 GB storage + bandwidth.
# -----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# -----------------------------------------------------------------------------
# Google OAuth (optional — currently unused; uncomment if you wire the
# Google social provider into auth.config.ts).
# -----------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
